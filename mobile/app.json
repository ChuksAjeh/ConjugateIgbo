{
  "expo": {
    "name": "Conjugate Igbo",
    "slug": "conjugate-igbo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications"
    ],
    "android": {
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "package": "com.chuksajeh.conjugateigbo"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
